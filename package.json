{
  "name": "bigred-link",
  "version": "1.7.0",
  "description": "A big red URL shortener",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">= 22.x",
    "npm": ">= 10.x"
  },
  "packageManager": "npm@11.12.0",
  "scripts": {
    "back-up-db": "node ./src/utils/back-up-db.js",
    "build": "vite build",
    "check-all-urls": "node ./src/utils/safe-browsing-url-check.js",
    "clean": "rm -rf ./build",
    "dev": "vite serve --port $PORT",
    "prebuild": "npm run clean",
    "preview": "vite preview",
    "start": "vercel dev",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "homepage": "https://bigred.link",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/mikesprague/bigred-link"
  },
  "bugs": {
    "url": "https://github.com/mikesprague/bigred-link/issues"
  },
  "dependencies": {
    "@bugsnag/core": "8.8.0",
    "@bugsnag/js": "8.8.1",
    "@bugsnag/plugin-react": "8.8.0",
    "@fortawesome/fontawesome-svg-core": "7.2.0",
    "@fortawesome/free-brands-svg-icons": "7.2.0",
    "@fortawesome/free-regular-svg-icons": "7.2.0",
    "@fortawesome/free-solid-svg-icons": "7.2.0",
    "@fortawesome/react-fontawesome": "3.3.0",
    "@supabase/supabase-js": "2.102.1",
    "clipboard-polyfill": "4.1.1",
    "dayjs": "1.11.20",
    "dompurify": "3.3.3",
    "dotenv": "17.4.1",
    "jotai": "2.19.1",
    "nanoid": "5.1.7",
    "prop-types": "15.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.2",
    "@vitejs/plugin-react-swc": "4.3.0",
    "cz-git": "1.12.0",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "stylelint": "17.6.0",
    "stylelint-config-standard": "40.0.0",
    "tailwindcss": "4.2.2",
    "vercel": "50.41.0",
    "vite": "8.0.7",
    "vite-plugin-html": "3.2.2",
    "vite-plugin-pwa": "1.2.0"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "ajv": "^8.18.0",
    "minimatch": "^10.2.4",
    "path-to-regexp": "^8.3.0",
    "picomatch": "^4.0.4",
    "serialize-javascript": "^7.0.5",
    "smol-toml": "^1.6.1",
    "tar": "^7.5.13",
    "undici": "^7.24.6",
    "vite": "8.0.7",
    "yauzl": "^3.2.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "volta": {
    "node": "24.14.0",
    "npm": "11.12.0"
  }
}

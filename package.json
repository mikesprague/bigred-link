{
  "name": "bigred-link",
  "version": "2.0.0-beta.6",
  "description": "A big red URL shortener",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">= 24.x",
    "npm": ">= 11.x"
  },
  "packageManager": "npm@11.17.0",
  "scripts": {
    "back-up-db": "npx tsx ./src/scripts/back-up-db.ts",
    "build": "npx tsc -b && npx vite build",
    "check-all-urls": "npx tsx ./src/scripts/safe-browsing-url-check.ts",
    "clean": "rm -rf ./build",
    "dev:vite": "npx vite serve --port $PORT",
    "format": "npx oxfmt src",
    "format:check": "npx oxfmt --check src",
    "lint": "npx oxlint .",
    "prebuild": "npm run clean",
    "preview": "npx vite preview",
    "start": "npx vercel dev --listen 3001",
    "test": "npm run format:check && npm run lint && npm run typecheck",
    "typecheck": "npx tsc --noEmit"
  },
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "homepage": "https://bigred.link",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/mikesprague/bigred-link"
  },
  "bugs": {
    "url": "https://github.com/mikesprague/bigred-link/issues"
  },
  "dependencies": {
    "@bugsnag/core": "8.9.0",
    "@bugsnag/js": "8.9.0",
    "@bugsnag/plugin-react": "8.9.0",
    "@fontsource-variable/inter": "5.2.8",
    "@tursodatabase/serverless": "1.2.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dayjs": "1.11.21",
    "dompurify": "3.4.11",
    "dotenv": "17.4.2",
    "jotai": "2.20.1",
    "lucide-react": "1.22.0",
    "nanoid": "5.1.16",
    "radix-ui": "1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "4.12.0",
    "tailwind-merge": "3.6.0",
    "tldts": "7.4.5",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "cz-git": "1.13.1",
    "globals": "17.7.0",
    "oxfmt": "0.56.0",
    "oxlint": "1.72.0",
    "tailwindcss": "4.3.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vercel": "54.18.6",
    "vite": "8.1.1",
    "vite-plugin-html": "3.2.2",
    "vite-plugin-pwa": "1.3.0"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "ajv": "^8.20.0",
    "esbuild": "^0.28.1",
    "glob": "^13.0.6",
    "js-yaml": "^4.2.0",
    "minimatch": "^10.2.5",
    "path-to-regexp": "^8.4.2",
    "smol-toml": "^1.6.1",
    "srvx": "^0.11.17",
    "tar": "^7.5.16",
    "undici": "^8.5.0"
  },
  "allowScripts": {
    "fsevents@2.3.3": true,
    "esbuild@0.28.1": true
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "volta": {
    "node": "24.18.0",
    "npm": "11.17.0"
  }
}

{
  "name": "bigred-link",
  "version": "1.9.0",
  "description": "A big red URL shortener",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">= 24.x",
    "npm": ">= 11.x"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
    "back-up-db": "tsx ./src/utils/back-up-db.ts",
    "build": "npx tsc -b && npx vite build",
    "check-all-urls": "tsx ./src/utils/safe-browsing-url-check.ts",
    "clean": "rm -rf ./build",
    "dev:vite": "npx vite serve --port $PORT",
    "format": "npx oxfmt src",
    "format:check": "npx oxfmt --check src",
    "lint": "npx oxlint .",
    "prebuild": "npm run clean",
    "preview": "npx vite preview",
    "start": "vercel dev --listen 3001",
    "test": "npm run format:check && npm run lint && npm run typecheck",
    "typecheck": "npx tsc --noEmit"
  },
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "homepage": "https://bigred.link",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/mikesprague/bigred-link"
  },
  "bugs": {
    "url": "https://github.com/mikesprague/bigred-link/issues"
  },
  "dependencies": {
    "@bugsnag/core": "8.9.0",
    "@bugsnag/js": "8.9.0",
    "@bugsnag/plugin-react": "8.9.0",
    "@tursodatabase/serverless": "1.2.0",
    "clipboard-polyfill": "4.1.1",
    "dayjs": "1.11.21",
    "dompurify": "3.4.8",
    "dotenv": "17.4.2",
    "jotai": "2.20.0",
    "lucide-react": "1.17.0",
    "nanoid": "5.1.11",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/typography": "0.5.20",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "cz-git": "1.13.1",
    "globals": "17.6.0",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "tailwindcss": "4.3.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vercel": "54.10.2",
    "vite": "8.0.16",
    "vite-plugin-html": "3.2.2",
    "vite-plugin-pwa": "1.3.0"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "ajv": "^8.20.0",
    "glob": "13.0.6",
    "minimatch": "^10.2.5",
    "path-to-regexp": "^8.4.2",
    "smol-toml": "^1.6.1",
    "srvx": "^0.11.16",
    "tar": "^7.5.16",
    "undici": "^8.4.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "volta": {
    "node": "24.16.0",
    "npm": "11.16.0"
  }
}
